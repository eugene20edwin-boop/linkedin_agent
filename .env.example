GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Use one of these author options:
# 1. Company page posting
LINKEDIN_ORGANIZATION_ID=

# 2. Explicit person/company URN
LINKEDIN_AUTHOR_URN=

# 3. Person ID fallback, converted to urn:li:person:...
LINKEDIN_PERSON_ID=

# Optional LinkedIn API version for /rest endpoints.
LINKEDIN_VERSION=202606

# Optional OAuth helper values for npm run token.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8745/callback
LINKEDIN_SCOPES=openid profile w_member_social w_organization_social
